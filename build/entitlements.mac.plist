<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Helm — macOS hardened-runtime entitlements.

  Allows the entitlements required by Electron + better-sqlite3 native modules
  + JIT for the Chromium renderer + outbound network for HTTP API + lark-cli
  subprocess. We deliberately do NOT request the App Sandbox entitlement so
  the helm-hook subprocess can write to ~/.cursor/hooks.json from outside
  the bundle.

  Used by:
    - electron-builder (mac.entitlements + mac.entitlementsInherit)
    - codesign --entitlements (when distribution is signed)
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
  </dict>
</plist>
